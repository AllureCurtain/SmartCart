# 智谱 API 配置示例
# 复制此文件到 ../Open-AutoGLM/.env 并填入真实的 API Key

ZHIPU_API_KEY=your-api-key-here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=autoglm-phone
ZHIPU_VISION_MODEL=glm-4v-flash

# ADB platform-tools directory.
# Windows example:
# ADB_PATH=C:\Users\YourName\AppData\Local\Android\Sdk\platform-tools
# macOS/Linux example:
# ADB_PATH=/Users/yourname/Library/Android/sdk/platform-tools
ADB_PATH=

# —— 搜索结束切回 App（单手机架构闭环，默认零配置）——
# 后端自动探测本机局域网 IP，拼 exp://<IP>:8081 切回 Expo Go，与 App 端
# expo-constants 读取的开发机 IP 一致。以下三项通常无需设置，仅当自动探测
# 不准（多网卡/指定 IP）或打生产 APK 自有 scheme 时覆盖：
# SMARTCART_RETURN_DEEPLINK=exp://192.168.1.100:8081   # 显式 deep link（覆盖自动探测）
# SMARTCART_RETURN_PACKAGE=host.exp.exponent            # 处理该 link 的包名（默认 Expo Go）
# SMARTCART_RETURN_REVERSE_PORTS=8081,8000              # 切回前重建的 adb reverse 端口（默认 Metro+后端）
